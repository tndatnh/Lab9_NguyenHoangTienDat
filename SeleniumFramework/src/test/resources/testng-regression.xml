<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite" verbose="1">

    <listeners>
        <listener class-name="framework.utils.RetryListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <test name="Full Login DDT Tests">
        <groups>
            <run>
                <!-- Chạy cả smoke lẫn regression → đọc cả 3 sheet -->
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginDDTTest"/>
        </classes>
    </test>

</suite>
      